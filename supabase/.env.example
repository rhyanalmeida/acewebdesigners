# ── Edge Function secrets ─────────────────────────────────────────────────────
# These live ONLY in Supabase, never in the client bundle or Netlify.
# Set them with:  supabase secrets set --env-file supabase/.env
# (copy this file to supabase/.env, fill in, and keep it gitignored)

# Meta Conversions API (dataset = the Contractors pixel)
META_CAPI_TOKEN=                       # Events Manager -> dataset -> Conversions API -> generate token
META_DATASET_ID=4230021860577001       # contractor pixel / CAPI dataset
META_DATASET_ID_MAIN=1703925480259996  # main pixel (optional, for main-site bookings)
META_DATASET_ID_RESTAURANT=1575254990791923  # restaurant "build your site" funnel — its OWN pixel/dataset
                                       # (matches RESTAURANT_PIXEL.pixelId in src/config/pixels.ts)
META_TEST_EVENT_CODE=                  # optional: forces events into Test Events while verifying

# Guards the internal `capi` test endpoint (so it can't be POSTed by anyone)
CAPI_INTERNAL_SECRET=

# GoHighLevel — messaging engine. We mirror every funnel stage into GHL via the v2
# API: upsert an enriched contact + a stage tag (funnel-lead/booked/showed/purchased)
# so UI-built workflows fire, and create a real GHL appointment on booking. Isolated
# in ghl.ts.
GHL_API_TOKEN=                         # GHL -> Settings -> Private Integrations (v2 API token / PIT)
GHL_LOCATION_ID=A2zlaOOL5JLn883XGWWl   # location that owns the workflows + custom fields
GHL_CALENDAR_ID=MseWjwAf3rDlJRoj1p75   # calendar `book` creates the real GHL appointment on
GHL_ASSIGNED_USER_ID=                  # GHL user id assigned to created appointments (required — appt create 422s without it)
# JSON map our_key -> GHL custom field id, printed by scripts/ghl-setup-custom-fields.mjs.
# Attribution (utm/fbc/fbp/ip/ua/landing/value) is synced to GHL only when this is set.
GHL_CUSTOM_FIELD_IDS=
# Legacy inbound-webhook relay (the old confirmation/reminders trigger). Kept ON during
# cutover; set GHL_LEGACY_WEBHOOK=false to retire once GHL-native workflows are verified.
GHL_INBOUND_WEBHOOK_URL=
GHL_LEGACY_WEBHOOK=true

# Restaurant funnel uses the SAME GHL account but its OWN tag set (restaurant-lead /
# -booked / -showed / -purchased) so restaurant leads never enroll in contractor
# workflows. Build the restaurant workflows in the GHL UI triggered by those tags.
# No extra secrets needed — isolation is by tag, not by account.

# Google Calendar (two-way sync) — service account shared onto the business
# calendar with "Make changes to events". JSON key, base64-encoded.
GOOGLE_SERVICE_ACCOUNT_B64=            # base64 of the service-account JSON key file
GOOGLE_CALENDAR_ID_CONTRACTOR=         # calendar id (e.g. you@gmail.com) shared with the SA
GOOGLE_CALENDAR_ID_MAIN=

# Stripe (deposits) -> Purchase CAPI
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Restaurant self-serve monthly plans (recurring Prices created in Stripe ->
# Products). `create-subscription` maps a plan KEY to one of these Price ids, so
# no price ids ship in the client bundle.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=

# Admin allow-list for mark-showed (comma-separated emails)
ADMIN_EMAILS=hello@acewebdesigners.com

# Optional AI copywriting for the restaurant builder (generate-copy fn). Uses the
# CHEAPEST model (Claude Haiku 4.5) + a tiny token cap + one call per click +
# per-session limit, so cost stays minimal. No-ops (503) when unset — the wizard
# works without it. Get a key at console.anthropic.com.
ANTHROPIC_API_KEY=

# Auto-injected by Supabase at runtime (do NOT set manually): SUPABASE_URL,
# SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY.
